{
  "name": "Statistic Mod",
  "author": "Aidanamite",
  "description": "Adds extra information to the HUD and other UIs",
  "version": "2.0.7",
  "license": "GNU AGPLv3",
  "icon": "icon.png",
  "banner": "banner.jpg",
  "gameVersion": "1.0",
  "updateUrl": "https://www.raftmodding.com/api/v1/mods/statistic-mod/version.txt",
  "isModPermanent": false,
  "excludedFiles": [],
  "requiredByAllPlayers": false,
  "modSettings": [
    {
      "name": "Clock Mode",
      "type": "combobox",
      "default": "Auto",
      "values": [ "None", "Bar", "Time", "Auto" ],
      "member": "clockSetting",
      "memberRealtime": true
    },
    {
      "name": "Stat Numbers",
      "type": "combobox",
      "default": "Decimals",
      "values": [ "None", "Rounded", "Decimals" ],
      "member": "statSetting",
      "memberRealtime": true
    },
    {
      "name": "Weather Display",
      "type": "checkbox",
      "default": true,
      "member": "showWeather",
      "memberRealtime": true
    },
    {
      "name": "Weather Timer",
      "type": "checkbox",
      "default": false,
      "member": "showWeatherTimer",
      "memberRealtime": true
    },
    {
      "name": "Shark Respawn Timer",
      "type": "checkbox",
      "default": true,
      "member": "showSharkRespawn",
      "memberRealtime": true
    },
    {
      "name": "Full Health Bars",
      "type": "checkbox",
      "default": true,
      "member": "showFullBars",
      "memberRealtime": true
    },
    {
      "name": "Story Objective",
      "type": "checkbox",
      "default": true,
      "member": "showStoryObjective",
      "memberRealtime": true
    },
    {
      "name": "Item Durability",
      "type": "checkbox",
      "default": true,
      "member": "showDurability",
      "memberRealtime": true
    },
    {
      "name": "Equipment Display",
      "type": "checkbox",
      "default": true,
      "member": "showHUDEquipment",
      "memberRealtime": true
    },
    {
      "name": "Raft Weight",
      "type": "checkbox",
      "default": true,
      "member": "showFoundations",
      "memberRealtime": true
    },
    {
      "name": "Compass",
      "type": "checkbox",
      "default": true,
      "member": "showCompass",
      "memberRealtime": true
    },
    {
      "name": "Speed Display",
      "type": "checkbox",
      "default": true,
      "member": "showSpeed",
      "memberRealtime": true
    },
    {
      "name": "Item IDs",
      "type": "checkbox",
      "default": false,
      "member": "showItemIds",
      "memberRealtime": true
    },
    {
      "name": "Raft Center",
      "type": "checkbox",
      "default": false,
      "member": "showCenter",
      "memberRealtime": true
    },
    {
      "name": "Crop Growth Percentage",
      "type": "checkbox",
      "default": true,
      "member": "showCropGrowth",
      "memberRealtime": true
    },
    {
      "name": "Battery Percentage",
      "type": "checkbox",
      "default": true,
      "member": "showBattery",
      "memberRealtime": true
    },
    {
      "name": "Raft Center Color",
      "type": "slider",
      "default": 510,
      "range": {
        "type": "custom",
        "min": 0,
        "max": 1529,
        "decimals": 0
      },
      "member": "center",
      "memberRealtime": true
    },
    {
      "name": "Health Bar Max Draw Distance",
      "type": "input",
      "default": 10,
      "mode": "DecimalNumber",
      "member": "barDrawDistance",
      "memberFallback": -1,
      "memberRealtime": true
    },
    {
      "name": "HUD X Offset",
      "type": "slider",
      "default": 0.042,
      "range": {
        "type": "percent",
        "min": 0,
        "max": 1,
        "decimals": 1
      },
      "member": "HUDPositionX",
      "memberRealtime": true
    },
    {
      "name": "HUD Y Offset",
      "type": "slider",
      "default": 0.042,
      "range": {
        "type": "percent",
        "min": 0,
        "max": 1,
        "decimals": 1
      },
      "member": "HUDPositionY",
      "memberRealtime": true
    },
    {
      "name": "Shark Alert",
      "type": "text"
    },
    {
      "name": "While Attacking Raft",
      "type": "checkbox",
      "default": true,
      "member": "sharkModeAttacking",
      "memberRealtime": true
    },
    {
      "name": "Attacking Color",
      "type": "slider",
      "default": 0,
      "range": {
        "type": "custom",
        "min": 0,
        "max": 1529,
        "decimals": 0
      },
      "member": "attacking",
      "memberRealtime": true
    },
    {
      "name": "While Charging Raft",
      "type": "checkbox",
      "default": true,
      "member": "sharkModeCharging",
      "memberRealtime": true
    },
    {
      "name": "Charging Color",
      "type": "slider",
      "default": 255,
      "range": {
        "type": "custom",
        "min": 0,
        "max": 1529,
        "decimals": 0
      },
      "member": "charging",
      "memberRealtime": true
    },
    {
      "name": "While Searching",
      "type": "checkbox",
      "default": false,
      "member": "sharkModeSearching",
      "memberRealtime": true
    },
    {
      "name": "Searching Color",
      "type": "slider",
      "default": 510,
      "range": {
        "type": "custom",
        "min": 0,
        "max": 1529,
        "decimals": 0
      },
      "member": "searching",
      "memberRealtime": true
    },
    {
      "name": "Alert Never Out of View",
      "type": "checkbox",
      "default": false,
      "member": "sharkAlertScreen",
      "memberRealtime": true
    },
    {
      "name": "exclusions",
      "type": "data",
      "member": "exclusions",
      "memberRealtime": true
    }
  ]
}